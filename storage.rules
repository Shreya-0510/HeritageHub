rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Media uploaded for each artwork under artworks/{artistId}/{artworkId}/...
    match /artworks/{artistId}/{artworkId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == artistId;
    }

    // Deny all other storage paths by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

